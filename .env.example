# ========================
# KiranaAI Environment Variables
# ========================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# NEVER commit your actual .env file!

# ─── Supabase Client (Public — safe for frontend) ───────────────
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

# ─── Supabase Database (PRIVATE — server-side only) ─────────────
# Used only by drizzle-kit for schema migrations.
# NEVER expose this in client code or commit to Git.
DATABASE_URL=""

# Connect to Supabase via connection pooling
DATABASE_URL=""
# Direct connection to the database. Used for migrations
DIRECT_URL=""